# Copy this file to .env for local development.

# Korean official legal information API
OPENLAW_OC=k-law-evidence-pipeline
OPENLAW_BASE_URL=https://www.law.go.kr

# Optional external LLM API. Leave empty for local-only mode.
GEMINI_API_KEY=
OPENAI_API_KEY=

# Privacy mode
KLEP_LOCAL_FIRST=true
KLEP_REQUIRE_EXTERNAL_API_CONFIRMATION=true
